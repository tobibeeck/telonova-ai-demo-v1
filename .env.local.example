# Azure OpenAI (GPT-5 mini, EU Region)
AZURE_OPENAI_ENDPOINT=https://telonova-ai.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Amazon Bedrock (Claude Sonnet 4.6, EU Region)
AWS_REGION=eu-central-1
AWS_BEARER_TOKEN=your-bearer-token-here

# Google Vertex AI (Gemini, EU Region) – Service Account JSON
# Datei nach data/gcp-service-account.json legen (nicht committen)
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=eu
GOOGLE_APPLICATION_CREDENTIALS=./data/gcp-service-account.json
GEMINI_MODEL=gemini-3.5-flash

# Lokales LLM (Ollama) für Pseudonymisierung
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# SQLite Datenbank
DATABASE_PATH=./data/telonova.db
